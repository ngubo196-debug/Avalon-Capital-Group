{
  "rewrites": [
    { "source": "/digital-card/saud",    "destination": "/saud-olla-digital-card.html" },
    { "source": "/digital-card/luyanda", "destination": "/acg-digital-card.html" },
    { "source": "/offers",               "destination": "/offers.html" },
    { "source": "/(.*)",                 "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
